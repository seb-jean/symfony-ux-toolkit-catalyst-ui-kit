<twig:Dropdown>
    <twig:Dropdown:Button>
        <twig:Button outline {{ ...dropdown_trigger_attrs }}>
            Options
            <twig:ux:icon name="heroicons:chevron-down-16-solid" data-slot="icon" />
        </twig:Button>
    </twig:Dropdown:Button>
    <twig:Dropdown:Menu anchor="bottom start">
        <twig:Dropdown:Section>
            <twig:Dropdown:Heading>Account</twig:Dropdown:Heading>
            <twig:Dropdown:Item href="#">
                <twig:Dropdown:Label>My profile</twig:Dropdown:Label>
            </twig:Dropdown:Item>
            <twig:Dropdown:Item href="#">
                <twig:Dropdown:Label>Settings</twig:Dropdown:Label>
            </twig:Dropdown:Item>
        </twig:Dropdown:Section>
        <twig:Dropdown:Divider />
        <twig:Dropdown:Section>
            <twig:Dropdown:Heading>Team</twig:Dropdown:Heading>
            <twig:Dropdown:Item href="#">
                <twig:Dropdown:Label>Members</twig:Dropdown:Label>
            </twig:Dropdown:Item>
            <twig:Dropdown:Item href="#">
                <twig:Dropdown:Label>Billing</twig:Dropdown:Label>
            </twig:Dropdown:Item>
        </twig:Dropdown:Section>
    </twig:Dropdown:Menu>
</twig:Dropdown>
