<twig:Dropdown>
    <twig:Dropdown:Button>
        <twig:Button outline {{ ...dropdown_trigger_attrs }}>
            Options
            <twig:ux:icon name="heroicons:chevron-down-16-solid" data-slot="icon" />
        </twig:Button>
    </twig:Dropdown:Button>
    <twig:Dropdown:Menu anchor="bottom start">
        <twig:Dropdown:Item href="#">
            <twig:ux:icon name="heroicons:eye-16-solid" data-slot="icon" />
            <twig:Dropdown:Label>View</twig:Dropdown:Label>
        </twig:Dropdown:Item>
        <twig:Dropdown:Item href="#">
            <twig:ux:icon name="heroicons:pencil-square-16-solid" data-slot="icon" />
            <twig:Dropdown:Label>Edit</twig:Dropdown:Label>
        </twig:Dropdown:Item>
        <twig:Dropdown:Divider />
        <twig:Dropdown:Item href="#">
            <twig:ux:icon name="heroicons:trash-16-solid" data-slot="icon" />
            <twig:Dropdown:Label>Delete</twig:Dropdown:Label>
        </twig:Dropdown:Item>
    </twig:Dropdown:Menu>
</twig:Dropdown>
