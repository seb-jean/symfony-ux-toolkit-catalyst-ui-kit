{# @prop href string|null The URL to the previous page. The link will be disabled when omitted. #}
{# @block content The text to display in the link. #}
{%- props href = null -%}
<span class="{{ ('grow basis-0 ' ~ attributes.render('class'))|trim }}">
    <twig:Button plain aria-label="Previous page" href="{{ href ?: false }}" disabled="{{ not href }}">
        <svg class="stroke-current" data-slot="icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2.75 8H13.25M2.75 8L5.25 5.5M2.75 8L5.25 10.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        {{- block(outerBlocks.content)|default('Previous') -}}
    </twig:Button>
</span>
