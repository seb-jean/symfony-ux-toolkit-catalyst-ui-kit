{# @block content The radio fields #}
<div
    class="{{ ('space-y-3 **:data-[slot=label]:font-normal has-data-[slot=description]:space-y-6 has-data-[slot=description]:**:data-[slot=label]:font-medium ' ~ attributes.render('class'))|trim }}"
    {{ attributes.defaults({
        'data-slot': 'control',
        'role': 'radiogroup',
    }) }}
>
    {%- block content %}{% endblock -%}
</div>
