<twig:Radio:Group aria-label="Resale and transfers" defaultValue="permit">
    <twig:Radio:Field>
        <twig:Radio name="resale" value="permit" />
        <twig:Fieldset:Label>Allow tickets to be resold</twig:Fieldset:Label>
    </twig:Radio:Field>
    <twig:Radio:Field>
        <twig:Radio name="resale" value="forbid" />
        <twig:Fieldset:Label>Don't allow tickets to be resold</twig:Fieldset:Label>
    </twig:Radio:Field>
</twig:Radio:Group>
