<twig:Radio:Group aria-label="Resale and transfers">
    <twig:Radio:Field>
        <twig:Radio color="sky" name="resale" value="permit" checked />
        <twig:Fieldset:Label>Allow tickets to be resold</twig:Fieldset:Label>
    </twig:Radio:Field>
    <twig:Radio:Field>
        <twig:Radio color="sky" name="resale" value="forbid" />
        <twig:Fieldset:Label>Don't allow tickets to be resold</twig:Fieldset:Label>
    </twig:Radio:Field>
</twig:Radio:Group>
