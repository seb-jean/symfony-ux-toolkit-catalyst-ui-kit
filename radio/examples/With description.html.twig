<twig:Radio:Group aria-label="Resale and transfers">
    <twig:Radio:Field>
        <twig:Radio name="resale" value="permit" checked />
        <twig:Fieldset:Label>Allow tickets to be resold</twig:Fieldset:Label>
        <twig:Fieldset:Description>Customers can resell or transfer their tickets if they can't make it to the event.</twig:Fieldset:Description>
    </twig:Radio:Field>
    <twig:Radio:Field>
        <twig:Radio name="resale" value="forbid" />
        <twig:Fieldset:Label>Don't allow tickets to be resold</twig:Fieldset:Label>
        <twig:Fieldset:Description>Tickets cannot be resold or transferred to another person.</twig:Fieldset:Description>
    </twig:Radio:Field>
</twig:Radio:Group>
