{# @prop id string Unique identifier used to generate internal Alert IDs #}
{# @prop size 'xs'|'sm'|'md'|'lg'|'xl'|'2xl'|'3xl'|'4xl'|'5xl' The max-width of the alert. Defaults to `'md'` #}
{# @prop open boolean Whether the alert is open or not. Defaults to `false` #}
{# @block button The element that opens the alert (spread `alert_button_attrs` onto it) #}
{# @block content The alert content, typically `Alert:Title`, `Alert:Description`, `Alert:Body` and `Alert:Actions` #}
{%- props id, size = 'md', open = false -%}
{%- set style = html_cva(
    base: [
        'row-start-2 w-full rounded-2xl bg-white p-8 shadow-lg ring-1 ring-zinc-950/10 sm:rounded-2xl sm:p-6 dark:bg-zinc-900 dark:ring-white/10 forced-colors:outline',
        'transition duration-100 will-change-transform data-closed:opacity-0 data-enter:ease-out data-closed:data-enter:scale-95 data-leave:ease-in',
    ],
    variants: {
        size: {
            'xs': 'sm:max-w-xs',
            'sm': 'sm:max-w-sm',
            'md': 'sm:max-w-md',
            'lg': 'sm:max-w-lg',
            'xl': 'sm:max-w-xl',
            '2xl': 'sm:max-w-2xl',
            '3xl': 'sm:max-w-3xl',
            '4xl': 'sm:max-w-4xl',
            '5xl': 'sm:max-w-5xl',
        },
    },
) -%}

{%- set _alert_id = 'alert-' ~ id -%}
{%- set _alert_titleId = _alert_id ~ '-title' -%}
{%- set _alert_descriptionId = _alert_id ~ '-description' -%}
{%- do provide('alert.titleId', _alert_titleId) -%}
{%- do provide('alert.descriptionId', _alert_descriptionId) -%}
{%- set alert_button_attrs = {
    command: 'show-modal',
    commandfor: _alert_id,
} -%}
{%- set alert_close_attrs = {
    command: 'close',
    commandfor: _alert_id,
} -%}
{%- block button %}{% endblock -%}
<el-dialog {% if open %}open{% endif %}>
    <dialog
        id="{{ _alert_id }}"
        aria-labelledby="{{ _alert_titleId }}"
        aria-describedby="{{ _alert_descriptionId }}"
        class="fixed inset-0 size-auto max-h-none max-w-none overflow-y-auto bg-transparent backdrop:bg-transparent"
        {{ attributes.without('class') }}
    >
        <el-dialog-backdrop class="fixed inset-0 flex w-screen justify-center overflow-y-auto bg-zinc-950/15 px-2 py-2 transition duration-100 focus:outline-0 data-closed:opacity-0 data-enter:ease-out data-leave:ease-in sm:px-6 sm:py-8 lg:px-8 lg:py-16 dark:bg-zinc-950/50"></el-dialog-backdrop>
        <div tabindex="0" class="grid min-h-full grid-rows-[1fr_auto_1fr] justify-items-center p-8 focus:outline-none sm:grid-rows-[1fr_auto_3fr] sm:p-4">
            <el-dialog-panel class="{{ style.apply({size}, attributes.render('class')) }}">
                {%- block content %}{% endblock -%}
            </el-dialog-panel>
        </div>
    </dialog>
</el-dialog>
