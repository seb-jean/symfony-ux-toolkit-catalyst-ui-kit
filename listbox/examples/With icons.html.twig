<div class="max-w-xs">
    <twig:Fieldset:Field>
        <twig:Fieldset:Label>Alignment</twig:Fieldset:Label>
        <twig:Listbox name="alignment" value="left">
            <twig:Listbox:Option value="left">
                <twig:ux:icon name="heroicons:bars-3-bottom-left" class="size-4" />
                <twig:Listbox:Label>Left</twig:Listbox:Label>
            </twig:Listbox:Option>
            <twig:Listbox:Option value="right">
                <twig:ux:icon name="heroicons:bars-3-bottom-right" class="size-4" />
                <twig:Listbox:Label>Right</twig:Listbox:Label>
            </twig:Listbox:Option>
            <twig:Listbox:Option value="justified">
                <twig:ux:icon name="heroicons:bars-3" class="size-4" />
                <twig:Listbox:Label>Justified</twig:Listbox:Label>
            </twig:Listbox:Option>
        </twig:Listbox>
    </twig:Fieldset:Field>
</div>
