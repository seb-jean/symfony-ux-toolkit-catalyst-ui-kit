<div class="max-w-xs">
    <twig:Fieldset:Field disabled>
        <twig:Fieldset:Label>Project status</twig:Fieldset:Label>
        <twig:Listbox name="status" value="delayed">
            <twig:Listbox:Option value="active"><twig:Listbox:Label>Active</twig:Listbox:Label></twig:Listbox:Option>
            <twig:Listbox:Option value="paused"><twig:Listbox:Label>Paused</twig:Listbox:Label></twig:Listbox:Option>
            <twig:Listbox:Option value="delayed"><twig:Listbox:Label>Delayed</twig:Listbox:Label></twig:Listbox:Option>
            <twig:Listbox:Option value="canceled"><twig:Listbox:Label>Canceled</twig:Listbox:Label></twig:Listbox:Option>
        </twig:Listbox>
    </twig:Fieldset:Field>
</div>
