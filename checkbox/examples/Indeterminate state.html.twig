<twig:Checkbox:Group role="group" aria-label="Discoverability">
    <twig:Checkbox:Field>
        <twig:Checkbox checked indeterminate />
        <twig:Fieldset:Label>Select all</twig:Fieldset:Label>
    </twig:Checkbox:Field>
    <twig:Checkbox:Field>
        <twig:Checkbox name="show_on_events_page" checked />
        <twig:Fieldset:Label>Show on events page</twig:Fieldset:Label>
    </twig:Checkbox:Field>
    <twig:Checkbox:Field>
        <twig:Checkbox name="allow_embedding" />
        <twig:Fieldset:Label>Allow embedding</twig:Fieldset:Label>
    </twig:Checkbox:Field>
</twig:Checkbox:Group>
