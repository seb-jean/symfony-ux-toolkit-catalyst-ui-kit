{%- set users = [
    {name: 'Leslie Alexander'},
    {name: 'Michael Foster'},
    {name: 'Dries Vincent'},
    {name: 'Bonnie Green'},
    {name: 'Courtney Henry'},
] -%}
<div class="w-full max-w-56">
    <twig:Combobox name="user" ariaLabel="Assigned to" defaultValue="Tom Cook">
        {%- for user in users -%}
            <twig:Combobox:Option value="{{ user.name }}">
                <twig:Combobox:Label>{{ user.name }}</twig:Combobox:Label>
            </twig:Combobox:Option>
        {%- endfor -%}
    </twig:Combobox>
</div>
