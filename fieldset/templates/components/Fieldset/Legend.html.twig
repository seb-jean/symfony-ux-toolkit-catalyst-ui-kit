{# @block content The legend text #}
<legend
    class="{{ ('text-base/6 font-semibold text-zinc-950 data-disabled:opacity-50 sm:text-sm/6 dark:text-white ' ~ attributes.render('class'))|trim }}"
    {{ attributes.defaults({
        'data-slot': 'legend',
    }) }}
>
    {%- block content %}{% endblock -%}
</legend>
