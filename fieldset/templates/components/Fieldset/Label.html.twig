{# @block content The label text. #}
{%- set _fieldsetField_disabled = inject('fieldsetField.disabled', false) -%}
<label
    data-slot="label"
    {% if _fieldsetField_disabled %}data-disabled{% endif %}
    class="{{ ('text-base/6 text-zinc-950 select-none data-disabled:opacity-50 sm:text-sm/6 dark:text-white ' ~ attributes.render('class'))|trim }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</label>
