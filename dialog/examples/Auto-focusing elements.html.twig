<twig:Dialog id="refund-payment">
    <twig:block name="button">
        <twig:Button type="button" {{ ...dialog_button_attrs }}>
            Refund payment
        </twig:Button>
    </twig:block>
    <twig:Dialog:Title>Refund payment</twig:Dialog:Title>
    <twig:Dialog:Description>
        The refund will be reflected in the customer’s bank account 2 to 3 business days after processing.
    </twig:Dialog:Description>
    <twig:Dialog:Body>
        <twig:Fieldset:Field>
            <twig:Fieldset:Label>Amount</twig:Fieldset:Label>
            <twig:Input name="amount" placeholder="$0.00" autofocus />
        </twig:Fieldset:Field>
    </twig:Dialog:Body>
    <twig:Dialog:Actions>
        <twig:Button plain {{ ...dialog_close_attrs }}>
            Cancel
        </twig:Button>
        <twig:Button {{ ...dialog_close_attrs }}>Refund</twig:Button>
    </twig:Dialog:Actions>
</twig:Dialog>
