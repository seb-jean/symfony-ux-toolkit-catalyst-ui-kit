{# @block content The title text. #}
{%- set _dialog_titleId = inject('dialog.titleId') -%}
<h2
    id="{{ _dialog_titleId }}"
    class="{{ ('text-lg/6 font-semibold text-balance text-zinc-950 sm:text-base/6 dark:text-white ' ~ attributes.render('class'))|trim }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</h2>
