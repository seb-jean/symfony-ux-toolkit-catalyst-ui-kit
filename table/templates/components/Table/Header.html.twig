{# @block content The header cell content #}
{%- set _table_bleed = inject('table.bleed', false) -%}
{%- set _table_grid = inject('table.grid', false) -%}
{%- set style = html_cva(
    base: 'border-b border-b-zinc-950/10 px-4 py-2 font-medium first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) dark:border-b-white/10',
    variants: {
        grid: {
            true: 'border-l border-l-zinc-950/5 first:border-l-0 dark:border-l-white/5',
        },
        bleed: {
            false: 'sm:first:pl-1 sm:last:pr-1',
        },
    },
) -%}
<th
    class="{{ style.apply({grid: _table_grid, bleed: _table_bleed}, attributes.render('class')) }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</th>
